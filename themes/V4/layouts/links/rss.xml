{{- $links := where .Site.RegularPages "Type" "links" -}}
{{- $sorted := sort $links "PublishDate" "desc" -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ with .Title }}{{.}} on {{ end }}{{ .Site.Title }}</title>
    <link>{{ .Permalink }}</link>
    <description>Recent links on {{ .Site.Title }}</description>
    <generator>Hugo -- gohugo.io</generator>{{ with .Site.Language.Locale }}
    <language>{{.}}</language>{{end}}{{ if gt (len $sorted) 0 }}
    <lastBuildDate>{{ (index $sorted 0).Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</lastBuildDate>{{ end }}
    {{- with .OutputFormats.Get "RSS" -}}
    {{ printf "<atom:link href=%q rel=\"self\" type=%q />" .Permalink .MediaType | safeHTML }}
    {{- end -}}
    {{ range first 20 $sorted }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      <description>
        {{ partial "components/notes/link.html" (dict "link_url" .Params.link_url "link_title" .Params.link_title "classes" "link") }}
        {{ .Content | html }}
      </description>
    </item>
    {{ end }}
  </channel>
</rss>
